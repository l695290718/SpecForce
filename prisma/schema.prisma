generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model DesignAsset {
  dbId        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  id          String
  type        String
  name        String
  code        String?
  description String
  domainId    String?
  applicationServiceId String
  scopePath   String
  payload     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([type])
  @@index([domainId])
  @@index([applicationServiceId])
  @@index([scopePath])
  @@unique([applicationServiceId, scopePath, id])
}

model Proposal {
  dbId        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  id          String
  title       String
  description String
  status      String
  domainId    String?
  applicationServiceId String
  scopePath   String
  payload     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([applicationServiceId])
  @@index([scopePath])
  @@unique([applicationServiceId, scopePath, id])
}

model ContextPack {
  dbId              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  id                String
  name              String
  proposalId        String
  targetAgent       String
  summary           String
  includedAssets    String
  constraints       String
  instructions      String
  generatedMarkdown String
  payload           String?
  applicationServiceId String
  scopePath           String
  createdAt         DateTime @default(now())

  @@index([proposalId])
  @@index([applicationServiceId])
  @@index([scopePath])
  @@unique([applicationServiceId, scopePath, id])
}

model GovernanceCheckSnapshot {
  id         String   @id @default(cuid())
  assetType  String
  assetId    String
  results    String
  createdAt  DateTime @default(now())

  @@index([assetType, assetId])
}

model AssetLink {
  dbId         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  id           String
  sourceType   String
  sourceId     String
  targetType   String
  targetId     String
  relationType String
  description  String?
  applicationServiceId String
  scopePath   String
  createdAt    DateTime @default(now())

  @@index([sourceType, sourceId])
  @@index([targetType, targetId])
  @@index([relationType])
  @@index([applicationServiceId])
  @@index([scopePath])
  @@unique([applicationServiceId, scopePath, id])
}

model ArchitectureScope {
  id          String   @id
  code        String   @unique
  name        String
  description String
  owner       String
  level       String
  parentId    String?
  scopePath   String   @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([parentId])
  @@index([level])
}

model ActorScopeGrant {
  id        String   @id @default(cuid())
  actorType String
  actorId   String
  scopeId   String
  action    String
  createdAt DateTime @default(now())

  @@unique([actorType, actorId, scopeId, action])
  @@index([actorType, actorId])
}

model AgentServiceWorkspace {
  id                   String   @id @default(cuid())
  agentType            String
  agentId              String
  applicationServiceId String
  recentAssetIds       String   @default("[]")
  pendingTasks         String   @default("[]")
  draftIds             String   @default("[]")
  generationHistory    String   @default("[]")
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@unique([agentType, agentId, applicationServiceId])
  @@index([applicationServiceId])
}

model AuditLog {
  id            String   @id @default(cuid())
  actorType     String
  actorId       String
  channel       String
  action        String
  targetType    String
  targetId      String
  inputSummary  String
  outputSummary String
  status        String
  errorMessage  String?
  createdAt     DateTime @default(now())

  @@index([actorType, actorId])
  @@index([channel, action])
  @@index([targetType, targetId])
  @@index([createdAt])
}

model AssetNode {
  dbId                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  enterpriseId         String
  applicationServiceId String
  scopePath            String
  nodeType             String
  logicalId            String
  rootAssetType        String
  rootAssetId          String
  parentNodeId         String?  @db.Uuid
  nodePath             String
  displayName          String
  metadata             Json     @default("{}") @db.JsonB
  version              BigInt
  lifecycleStatus      String
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  parent               AssetNode?           @relation("AssetNodeParent", fields: [parentNodeId], references: [dbId])
  children             AssetNode[]           @relation("AssetNodeParent")
  sourceRelationships  RelationshipCurrent[] @relation("RelationshipSource")
  targetRelationships  RelationshipCurrent[] @relation("RelationshipTarget")
  impactResultNodes    ImpactResultNode[]    @relation("ImpactResultAssetNode")
  startingImpactPaths  ImpactResultPath[]    @relation("ImpactPathStartNode")
  endingImpactPaths    ImpactResultPath[]    @relation("ImpactPathEndNode")

  @@unique([enterpriseId, applicationServiceId, scopePath, nodeType, logicalId])
  @@index([enterpriseId, applicationServiceId, scopePath, rootAssetType, rootAssetId])
  @@index([enterpriseId, applicationServiceId, scopePath, parentNodeId])
}

model RelationshipCurrent {
  dbId                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  enterpriseId         String
  applicationServiceId String
  scopePath            String
  sourceNodeId         String   @db.Uuid
  targetNodeId         String   @db.Uuid
  relationType         String
  strength             String
  confidence           Float
  source               String
  sourceReference      String   @default("")
  validFrom            DateTime @default(now())
  validTo              DateTime?
  version              BigInt
  lifecycleStatus      String   @default("ACTIVE")
  metadata             Json     @default("{}") @db.JsonB
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  sourceNode           AssetNode          @relation("RelationshipSource", fields: [sourceNodeId], references: [dbId])
  targetNode           AssetNode          @relation("RelationshipTarget", fields: [targetNodeId], references: [dbId])
  events               RelationshipEvent[] @relation("RelationshipEventCurrent")

  @@unique([enterpriseId, applicationServiceId, scopePath, sourceNodeId, targetNodeId, relationType, source, sourceReference])
  @@index([enterpriseId, applicationServiceId, scopePath, sourceNodeId, relationType], map: "RelationshipCurrent_scope_source_idx")
  @@index([enterpriseId, applicationServiceId, scopePath, targetNodeId, relationType], map: "RelationshipCurrent_scope_target_idx")
}

model RelationshipEvent {
  dbId                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  enterpriseId         String
  applicationServiceId String
  scopePath            String
  relationshipId       String   @db.Uuid
  action               String
  priorVersion         BigInt?
  newVersion           BigInt
  graphVersion         BigInt
  actorType            String
  actorId              String
  channel              String
  correlationId        String
  idempotencyKey       String
  source               String
  snapshot             Json     @default("{}") @db.JsonB
  createdAt            DateTime @default(now())

  relationship         RelationshipCurrent @relation("RelationshipEventCurrent", fields: [relationshipId], references: [dbId])
  outbox               RelationshipOutbox? @relation("RelationshipEventOutbox")

  @@unique([enterpriseId, applicationServiceId, scopePath, idempotencyKey])
  @@index([enterpriseId, applicationServiceId, scopePath, relationshipId, createdAt])
}

model RelationshipOutbox {
  dbId                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  enterpriseId         String
  applicationServiceId String
  scopePath            String
  relationshipEventId  String   @unique @db.Uuid
  graphVersion         BigInt
  eventType            String
  payload              Json     @default("{}") @db.JsonB
  status               String
  idempotencyKey       String
  availableAt          DateTime @default(now())
  sentAt               DateTime?
  attemptCount         Int      @default(0)
  lastError            String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  relationshipEvent    RelationshipEvent @relation("RelationshipEventOutbox", fields: [relationshipEventId], references: [dbId])

  @@unique([enterpriseId, applicationServiceId, scopePath, idempotencyKey])
  @@index([enterpriseId, applicationServiceId, scopePath, status, availableAt])
}

model ProjectionCheckpoint {
  dbId                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  enterpriseId         String
  applicationServiceId String
  scopePath            String
  partitionId          String
  lastEventId          String?  @db.Uuid
  projectionVersion    BigInt
  projectedAt          DateTime?
  status               String
  error                String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@unique([enterpriseId, applicationServiceId, scopePath, partitionId])
  @@index([enterpriseId, applicationServiceId, scopePath, projectionVersion])
}

model ImpactAnalysisRun {
  dbId                  String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  enterpriseId          String
  applicationServiceId  String
  scopePath             String
  proposalId            String
  status                String
  stopReason            String?
  assetVersion          BigInt
  relationshipVersion   BigInt
  ontologyVersion       String
  requiredGraphVersion  BigInt
  actualGraphCheckpoint BigInt?
  authorizationSnapshot Json     @default("{}") @db.JsonB
  budgets               Json     @default("{}") @db.JsonB
  summary               Json     @default("{}") @db.JsonB
  unexploredFrontierCount Int    @default(0)
  startedAt             DateTime @default(now())
  completedAt           DateTime?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  resultNodes           ImpactResultNode[] @relation("ImpactRunNodes")

  @@index([enterpriseId, applicationServiceId, scopePath, status, createdAt], map: "ImpactAnalysisRun_scope_status_idx")
  @@index([enterpriseId, applicationServiceId, scopePath, proposalId], map: "ImpactAnalysisRun_scope_proposal_idx")
}

model ImpactResultNode {
  dbId                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  enterpriseId         String
  applicationServiceId String
  scopePath            String
  impactAnalysisRunId  String   @db.Uuid
  nodeId               String   @db.Uuid
  impactLevel          String
  certainty            String
  depth                Int
  confidence           Float
  primaryPath          Json     @default("{}") @db.JsonB
  alternativePaths     Json     @default("[]") @db.JsonB
  matchedRules         Json     @default("[]") @db.JsonB
  recommendedActions   Json     @default("[]") @db.JsonB
  owner                String?
  snapshot             Json     @default("{}") @db.JsonB
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  impactAnalysisRun    ImpactAnalysisRun @relation("ImpactRunNodes", fields: [impactAnalysisRunId], references: [dbId])
  node                 AssetNode         @relation("ImpactResultAssetNode", fields: [nodeId], references: [dbId])
  paths                ImpactResultPath[] @relation("ImpactResultNodePaths")

  @@unique([impactAnalysisRunId, nodeId])
  @@index([enterpriseId, applicationServiceId, scopePath, impactAnalysisRunId])
}

model ImpactResultPath {
  dbId                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  enterpriseId         String
  applicationServiceId String
  scopePath            String
  impactResultNodeId   String   @db.Uuid
  startNodeId          String   @db.Uuid
  endNodeId            String   @db.Uuid
  rank                 Int
  certainty            String
  confidence           Float
  path                 Json     @default("{}") @db.JsonB
  createdAt            DateTime @default(now())

  impactResultNode     ImpactResultNode @relation("ImpactResultNodePaths", fields: [impactResultNodeId], references: [dbId])
  startNode            AssetNode        @relation("ImpactPathStartNode", fields: [startNodeId], references: [dbId])
  endNode              AssetNode        @relation("ImpactPathEndNode", fields: [endNodeId], references: [dbId])

  @@unique([impactResultNodeId, rank])
  @@index([enterpriseId, applicationServiceId, scopePath, impactResultNodeId])
}
