generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model DesignAsset {
  id          String   @id
  type        String
  name        String
  code        String?
  description String
  domainId    String?
  applicationServiceId String?
  scopePath   String?
  payload     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([type])
  @@index([domainId])
  @@index([applicationServiceId])
  @@index([scopePath])
}

model Proposal {
  id          String   @id
  title       String
  description String
  status      String
  domainId    String?
  applicationServiceId String?
  scopePath   String?
  payload     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([applicationServiceId])
  @@index([scopePath])
}

model ContextPack {
  id                String   @id
  name              String
  proposalId        String
  targetAgent       String
  summary           String
  includedAssets    String
  constraints       String
  instructions      String
  generatedMarkdown String
  payload           String?
  applicationServiceId String?
  scopePath           String?
  createdAt         DateTime @default(now())

  @@index([proposalId])
  @@index([applicationServiceId])
  @@index([scopePath])
}

model GovernanceCheckSnapshot {
  id         String   @id @default(cuid())
  assetType  String
  assetId    String
  results    String
  createdAt  DateTime @default(now())

  @@index([assetType, assetId])
}

model AssetLink {
  id           String   @id
  sourceType   String
  sourceId     String
  targetType   String
  targetId     String
  relationType String
  description  String?
  applicationServiceId String?
  scopePath   String?
  createdAt    DateTime @default(now())

  @@index([sourceType, sourceId])
  @@index([targetType, targetId])
  @@index([relationType])
  @@index([applicationServiceId])
  @@index([scopePath])
}

model ArchitectureScope {
  id          String   @id
  code        String   @unique
  name        String
  description String
  owner       String
  level       String
  parentId    String?
  scopePath   String   @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([parentId])
  @@index([level])
}

model ActorScopeGrant {
  id        String   @id @default(cuid())
  actorType String
  actorId   String
  scopeId   String
  action    String
  createdAt DateTime @default(now())

  @@unique([actorType, actorId, scopeId, action])
  @@index([actorType, actorId])
}

model AgentServiceWorkspace {
  id                   String   @id @default(cuid())
  agentType            String
  agentId              String
  applicationServiceId String
  recentAssetIds       String   @default("[]")
  pendingTasks         String   @default("[]")
  draftIds             String   @default("[]")
  generationHistory    String   @default("[]")
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@unique([agentType, agentId, applicationServiceId])
  @@index([applicationServiceId])
}

model AuditLog {
  id            String   @id @default(cuid())
  actorType     String
  actorId       String
  channel       String
  action        String
  targetType    String
  targetId      String
  inputSummary  String
  outputSummary String
  status        String
  errorMessage  String?
  createdAt     DateTime @default(now())

  @@index([actorType, actorId])
  @@index([channel, action])
  @@index([targetType, targetId])
  @@index([createdAt])
}
